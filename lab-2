#include <ESP8266WiFi.h>
#include <ESP8266WebServer.h>
#include <SoftwareSerial.h>

#define RX_PIN 5
#define TX_PIN 4
SoftwareSerial uart(RX_PIN, TX_PIN);

const uint32_t UART_BAUD = 9600;
const char COMMAND = 'M';

const char* ssid = "ESP_Vl";
const char* password = "1234567890";

ESP8266WebServer server(80);

const uint8_t LED_PINS[] = {2, 12, 13}; 
const uint8_t MY_BUTTON_PIN = 0;
const uint8_t PARTNER_BUTTON_PIN = 15;

volatile uint32_t lastInterruptTime = 0;
const uint8_t debounceDelay = 50;

volatile bool myButtonTriggered = false;
volatile bool partnerButtonTriggered = false;

uint8_t currentMode = 0;
uint8_t currentStep = 0;
uint32_t lastLedTime = 0;
const uint16_t ledInterval = 300;

const uint8_t mode0_steps[] = {0, 1, 2};
const uint8_t mode1_steps[] = {2, 1, 0, 1};

String currentModeStr = "Mode 0";
String currentLedColor = "Yellow";

const String ledColors[3] = {"Yellow", "Red", "Green"};

void IRAM_ATTR handleMyButton() {
  uint32_t t = millis();
  if (t - lastInterruptTime > debounceDelay) {
    // ЗМІНЕНО: перевіряємо HIGH, бо при відпусканні кнопки з INPUT_PULLUP рівень стає високим
    if (digitalRead(MY_BUTTON_PIN) == HIGH) myButtonTriggered = true;
    lastInterruptTime = t;
  }
}

void IRAM_ATTR handlePartnerButton() {
  uint32_t t = millis();
  if (t - lastInterruptTime > debounceDelay) {
    if (digitalRead(PARTNER_BUTTON_PIN) == LOW) partnerButtonTriggered = true;
    lastInterruptTime = t;
  }
}

void sendCommandToMain() {
  uart.write(COMMAND);
  uart.flush();
  Serial.println("Sent 'M' to main MCU");
}

void checkUart() {
  static uint32_t lastCmdTime = 0;
  
  if (uart.available()) {
    char c = uart.read();
    Serial.printf("Received from main MCU: 0x%02X\n", c);
    
    uint32_t currentTime = millis();
    
    if (((c & 0x1F) == (COMMAND & 0x1F)) && (currentTime - lastCmdTime > 400)) {
      currentMode = !currentMode;
      currentStep = 0;
      lastCmdTime = currentTime;
      
      while(uart.available()) uart.read();
      
      Serial.printf("Command recognized: 0x%02X. Mode changed to %d\n", c, currentMode);
      
      currentModeStr = currentMode == 0 ? "Mode 0" : "Mode 1";
    }
  }
}

const char MAIN_page[] PROGMEM = R"=====(
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Partner ESP8266</title>
  <style>
    body { text-align: center; font-family: sans-serif; margin-top: 30px; background: #1e1e1e; color: #fff; }
    .status { font-size: 28px; margin: 20px auto; padding: 20px; background: #333; border-radius: 12px; width: 90%; max-width: 500px; }
    .led { font-size: 32px; font-weight: bold; }
    .btn { padding: 18px 40px; font-size: 22px; margin: 12px; border: none; border-radius: 12px; cursor: pointer; }
    .btn1 { background: #007BFF; color: white; }
    .btn2 { background: #FF5722; color: white; }
  </style>
</head>
<body>
  <div id="status" class="status">Mode: 0 | LED: Yellow</div>
  
  <button class="btn btn1" onclick="fetch('/toggleMe')">Change Local Algorithm</button><br>
  <button class="btn btn2" onclick="fetch('/togglePartner')">Change Main MCU Algorithm</button>

  <script>
    function update() {
      fetch('/status')
        .then(r => r.text())
        .then(txt => document.getElementById('status').innerHTML = txt);
    }
    setInterval(update, 150);
    update();
  </script>
</body>
</html>
)=====";

void handleRoot() { server.send(200, "text/html", MAIN_page); }
void handleToggleMe() { myButtonTriggered = true; server.send(200, "text/plain", "OK"); }
void handleTogglePartner() { partnerButtonTriggered = true; server.send(200, "text/plain", "OK"); }

void handleStatus() {
  String resp = "Mode: " + String(currentMode) + 
                " | LED: <span class='led'>" + currentLedColor + "</span>";
  server.send(200, "text/plain", resp);
}

void processMyButton() {
  if (myButtonTriggered) {
    currentMode = !currentMode;
    currentStep = 0;
    myButtonTriggered = false;
    
    currentModeStr = currentMode == 0 ? "Mode 0" : "Mode 1";
    Serial.println(currentMode == 0 ? "=== Local Mode changed to Mode 0 ===" : "=== Local Mode changed to Mode 1 ===");
  }
}

void processPartnerButton() {
  if (partnerButtonTriggered) {
    sendCommandToMain();
    partnerButtonTriggered = false;
  }
}

void updateAnimation() {
  if (millis() - lastLedTime >= ledInterval) {
    lastLedTime = millis();

    for (uint8_t i = 0; i < 3; i++) digitalWrite(LED_PINS[i], LOW);

    uint8_t ledIndex;
    if (currentMode == 0) {
      ledIndex = mode0_steps[currentStep];
      currentStep = (currentStep + 1) % 3;
    } else {
      ledIndex = mode1_steps[currentStep];
      currentStep = (currentStep + 1) % 4;
    }

    digitalWrite(LED_PINS[ledIndex], HIGH);
    currentLedColor = ledColors[ledIndex];
  }
}

void setup() {
  Serial.begin(115200);
  Serial.println("\n=== Partner ESP8266 Starting ===");

  for (uint8_t i = 0; i < 3; i++) {
    pinMode(LED_PINS[i], OUTPUT);
    digitalWrite(LED_PINS[i], LOW);
  }

  pinMode(MY_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PARTNER_BUTTON_PIN, INPUT);

  // ЗМІНЕНО: FALLING на RISING для першої кнопки (спрацьовує при відпусканні)
  attachInterrupt(digitalPinToInterrupt(MY_BUTTON_PIN), handleMyButton, RISING);
  attachInterrupt(digitalPinToInterrupt(PARTNER_BUTTON_PIN), handlePartnerButton, FALLING);

  uart.begin(UART_BAUD, SWSERIAL_5O2);
  Serial.printf("UART started: %d baud, 5 data, odd parity, 2 stop bits\n", UART_BAUD);

  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);

  server.on("/", handleRoot);
  server.on("/toggleMe", handleToggleMe);
  server.on("/togglePartner", handleTogglePartner);
  server.on("/status", handleStatus);
  server.begin();

  Serial.println("Web server started → http://192.168.4.1");
  Serial.println("Partner ready!\n");
}

void loop() {
  server.handleClient();
  
  processMyButton();
  processPartnerButton();
  updateAnimation();
  checkUart();
}
